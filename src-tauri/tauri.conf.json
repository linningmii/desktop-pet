{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desktop Pet",
  "version": "0.4.0",
  "identifier": "com.linningmii.desktop-pet",
  "build": {
    "frontendDist": "../app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "pet",
        "title": "Desktop Pet",
        "width": 48,
        "height": 48,
        "x": 100,
        "y": 100,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focusable": false
      }
    ],
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
